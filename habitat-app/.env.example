# NextAuth
# For local development:
# NEXTAUTH_URL=http://localhost:3001
# For production (replace with your actual server URL):
# NEXTAUTH_URL=http://your-ec2-hostname.compute.amazonaws.com:3001
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your-secret-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# MongoDB (overridden by docker-compose for containerized deployments)
MONGODB_URI=mongodb://localhost:27017/habitat_db
